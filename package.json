{
  "name": "@asjk/codex-history",
  "version": "0.0.0",
  "description": "Terminal tool for inspecting and safely purging local Codex conversation history.",
  "type": "module",
  "bin": {
    "codex-history": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --cache=false"
  },
  "keywords": [
    "codex",
    "cli",
    "history",
    "purge"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
