{
  "name": "@liuyoumi/codex-history",
  "version": "0.1.4",
  "description": "CLI for listing and safely purging local Codex conversation history",
  "type": "module",
  "bin": {
    "codex-history": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --cache=false"
  },
  "keywords": [
    "codex",
    "cli",
    "history",
    "purge"
  ],
  "author": "liuyoumi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/liuyoumi/codex-history.git"
  },
  "bugs": {
    "url": "https://github.com/liuyoumi/codex-history/issues"
  },
  "homepage": "https://github.com/liuyoumi/codex-history#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
